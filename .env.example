# Split-Flap — Docker configuration overrides.
#
# Everything here is OPTIONAL. With no .env file, the defaults below apply.
# To customize: `cp .env.example .env`, edit, then
# `docker compose pull && docker compose up -d`.

# Host port the display + API are served on. The container always listens on
# 3001 internally; this only changes the port you open in a browser.
HOST_PORT=8080

# Which published image tag to run (issue #50). `latest` tracks main and
# auto-updates; pin to a specific build to freeze/rollback, e.g.
# IMAGE_TAG=sha-1a2b3c4 (then `docker compose pull && docker compose up -d`).
IMAGE_TAG=latest

# How often Watchtower checks GHCR for a newer image, in seconds (default ~20
# min). Set lower for faster rollouts, higher to check less often.
WATCHTOWER_POLL_INTERVAL=1200

# Timezone for the info-screen clock (IANA name). Without this the container
# runs in UTC and the clock will be wrong. Examples: America/Chicago,
# America/New_York, Europe/London. Find yours: `timedatectl list-timezones`.
TZ=America/Chicago

# Boot display mode:
#   qlock = word clock (lightest on the Pi 3B+; no flip animation)
#   flip  = split-flap info screen (date + 24h clock)
DEFAULT_MODE=qlock

# Boot word-clock language (qlock mode only): en | ar (Arabic, RTL)
DEFAULT_QLOCK_LANG=en

# State file path inside the container. Persisted on the `split-flap-data`
# Docker volume so the last message/mode/theme/sound survive restarts.
# Set to "off" to run fully in-memory (resets on restart).
PERSIST_FILE=/data/.state.json

# Split-flap animation speed. NOTE: baked into the client at BUILD time, so the
# published GHCR image is fixed at the default (2). This only applies when you
# build the image yourself via docker-compose.build.yml.
#   1 = original mechanical speed — gentlest on a Pi 3B+
#   2 = default (twice as fast)
FLIP_SPEED=2
